{
  "info": {
    "name": "City Events Discovery System",
    "description": "API collection for City Events Discovery and Exploration System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Common",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/signup", "host": ["{{base_url}}"], "path": ["signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\",\n  \"mobile_no\": \"9876543210\",\n  \"city\": \"Ahmedabad\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"User\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        },
        {
          "name": "Session",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/session", "host": ["{{base_url}}"], "path": ["session"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/changePassword", "host": ["{{base_url}}"], "path": ["changePassword"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"newPassword\": \"newpass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🌐 Public",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Get All Festivals",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/festivals", "host": ["{{base_url}}"], "path": ["festivals"] }
          }
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/events",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [
                { "key": "category_id", "value": "", "disabled": true },
                { "key": "festival_id", "value": "", "disabled": true },
                { "key": "min_price", "value": "", "disabled": true },
                { "key": "max_price", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Events by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/events?category_id=CATEGORY_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [{ "key": "category_id", "value": "CATEGORY_ID_HERE" }]
            }
          }
        },
        {
          "name": "Get Events by Festival",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/events?festival_id=FESTIVAL_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [{ "key": "festival_id", "value": "FESTIVAL_ID_HERE" }]
            }
          }
        },
        {
          "name": "Get Events by Price Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/events?min_price=100&max_price=500",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [
                { "key": "min_price", "value": "100" },
                { "key": "max_price", "value": "500" }
              ]
            }
          }
        },
        {
          "name": "Get Event Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/events/EVENT_ID_HERE",
              "host": ["{{base_url}}"],
              "path": ["events", "EVENT_ID_HERE"]
            }
          }
        },
        {
          "name": "Get All Feedbacks",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/feedbacks", "host": ["{{base_url}}"], "path": ["feedbacks"] }
          }
        }
      ]
    },
    {
      "name": "🟢 User (Session Required)",
      "item": [
        {
          "name": "Update Profile",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/user/updateProfile", "host": ["{{base_url}}"], "path": ["user", "updateProfile"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe Updated\",\n  \"mobile_no\": \"9876543210\",\n  \"city\": \"Surat\",\n  \"profile_image\": \"https://example.com/profile.jpg\"\n}"
            }
          }
        },
        {
          "name": "Add Event Inquiry",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/user/addEventInquiry", "host": ["{{base_url}}"], "path": ["user", "addEventInquiry"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"EVENT_ID_HERE\",\n  \"inquiry_message\": \"Is there parking available near the venue?\"\n}"
            }
          }
        },
        {
          "name": "My Event Inquiries",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/user/myEventInquiries", "host": ["{{base_url}}"], "path": ["user", "myEventInquiries"] }
          }
        },
        {
          "name": "Add General Inquiry",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/user/addGeneralInquiry", "host": ["{{base_url}}"], "path": ["user", "addGeneralInquiry"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inquiry_subject\": \"How to list a new event?\",\n  \"inquiry_message\": \"I want to know how I can get my event listed on this platform.\"\n}"
            }
          }
        },
        {
          "name": "My General Inquiries",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/user/myGeneralInquiries", "host": ["{{base_url}}"], "path": ["user", "myGeneralInquiries"] }
          }
        },
        {
          "name": "Add Feedback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/user/addFeedback", "host": ["{{base_url}}"], "path": ["user", "addFeedback"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"feedback_message\": \"Amazing platform! Very easy to find events.\",\n  \"rating\": 5\n}"
            }
          }
        }
      ]
    }
  ]
}
